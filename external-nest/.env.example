# IP del nodo minikube — obtener con: minikube ip
MINIKUBE_IP=192.168.49.2

# Token compartido con el cluster K8s para autenticar el canal de telemetría
# Debe coincidir con el valor del Secret alloy/external-secret.yaml
ALLOY_BEARER_TOKEN=change-me-generate-a-strong-token

# Endpoint HTTP del receiver externo del Alloy del cluster
CLUSTER_ALLOY_ENDPOINT=http://192.168.49.2:30320

# Credenciales Langfuse — el host apunta al NodePort expuesto en el cluster (30900)
LANGFUSE_PUBLIC_KEY=pk-lf-poc00000000000000000000000001
LANGFUSE_SECRET_KEY=sk-lf-poc00000000000000000000000001
LANGFUSE_HOST=http://192.168.49.2:30900

# Keycloak JWT — acceso vía Ingress nip.io
KEYCLOAK_URL=http://http://keycloak.192.168.49.2.nip.io
KEYCLOAK_REALM=poc
KEYCLOAK_AUDIENCE=backend-nest-external
