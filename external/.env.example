# Token compartido con el cluster K8s para autenticar el canal de telemetría
# Debe coincidir con el valor del Secret alloy/external-secret.yaml
ALLOY_BEARER_TOKEN=change-me-generate-a-strong-token

# Endpoint HTTP del receiver externo del Alloy del cluster
# Formato: http://<IP-nodo-k8s>:<nodePort>  — el NodePort es 30320 (puerto 4320)
CLUSTER_ALLOY_ENDPOINT=http://<CLUSTER_NODE_IP>:30320

# Credenciales Langfuse — el host apunta al NodePort expuesto en el cluster (30900)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://<CLUSTER_NODE_IP>:30900
