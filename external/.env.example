# IP del nodo minikube — obtener con: minikube ip
# Se usa para construir las URLs de los NodePorts y del Ingress de Keycloak.
MINIKUBE_IP=<output-de-minikube-ip>

# Token compartido con el cluster K8s para autenticar el canal de telemetría
# Debe coincidir con el valor del Secret alloy/external-secret.yaml
ALLOY_BEARER_TOKEN=change-me-generate-a-strong-token

# Endpoint HTTP del receiver externo del Alloy del cluster
# Formato: http://<MINIKUBE_IP>:<nodePort>  — el NodePort es 30320 (puerto 4320)
CLUSTER_ALLOY_ENDPOINT=http://<output-de-minikube-ip>:30320

# Credenciales Langfuse — el host apunta al NodePort expuesto en el cluster (30900)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://<output-de-minikube-ip>:30900

# Keycloak JWT — acceso vía Ingress nip.io (resuelve automáticamente a MINIKUBE_IP)
KEYCLOAK_URL=http://keycloak.<output-de-minikube-ip>.nip.io
KEYCLOAK_REALM=poc
KEYCLOAK_AUDIENCE=backend-external
